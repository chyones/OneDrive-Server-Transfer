# .NET build output
**/bin/
**/obj/

# Generated Windows publish output
artifacts/win-x64/*
!artifacts/win-x64/.gitkeep

# Generated raw source-validation output
artifacts/source/*
!artifacts/source/.gitkeep

# Durable redacted evidence summaries are intentionally committed
!artifacts/evidence/
!artifacts/evidence/**

# User-specific IDE files
.vs/
.vscode/*
!.vscode/extensions.json
*.user
*.suo
*.userosscache
*.sln.docstates

# JetBrains
.idea/
*.sln.iml

# Test and coverage output
TestResults/
coverage/
coverage.*
*.trx

# Logs and runtime transfer data
*.log
*.partial
_TransferReport/
OneDriveData/

# Local configuration and secrets
appsettings.json
appsettings.*.json
!appsettings.example.json
.env
.env.*
*.pfx
*.p12
*.pem
*.key
*.cer
*.crt

# SBOM and scan working output
artifacts/**/*.sarif
artifacts/**/*.spdx.json
artifacts/**/*.cyclonedx.json
!artifacts/evidence/*.json

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Optional packages
*.zip