{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "%LOCALAPPDATA%/OneDriveServerTransfer/logs/app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "TransferState": {
    "SchemaVersion": 1,
    "PathMappingVersion": 1
  },
  "Authentication": {
    "TenantId": "CONFIGURE_TENANT_ID",
    "ClientId": "CONFIGURE_CLIENT_ID",
    "AuthorizedOperatorObjectIds": [],
    "RememberSignInDefault": true,
    "RedirectUri": "http://localhost"
  },
  "SourceResolution": {
    "TenantOneDriveHost": "CONFIGURE_TENANT_ONEDRIVE_HOST"
  }
}
