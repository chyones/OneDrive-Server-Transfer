<Window x:Class="OneDriveServerTransfer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OneDrive Server Transfer" Height="480" Width="840"
        WindowStartupLocation="CenterScreen">
    <!--
        Minimal M1 shell only. The one-window transfer workflow (sign-in, employee
        source input, destination, Scan, Start Copy, progress, reports) is implemented
        in later milestones; no transfer controls exist yet.
    -->
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="{Binding WindowTitle}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,0" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
